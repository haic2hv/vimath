generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id           String     @id @default(uuid())
  userId       String     @unique
  email        String
  role         String     @default("user")
  tokenBalance Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orders       Order[]
  purchases    Purchase[]
}

model Order {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  type        String   // "topup" or "purchase"
  amount      Int      // VND amount (for topup), 0 for purchase
  tokenAmount Int      // tokens added (topup) or spent (purchase)
  status      String   @default("pending")
  sepayRef    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Purchase {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  itemType    String   // "exam" or "course"
  itemSlug    String
  tokenAmount Int
  createdAt   DateTime @default(now())

  @@unique([profileId, itemType, itemSlug])
}
