generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  email       String
  isPremium   Boolean  @default(false)
  premiumUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
